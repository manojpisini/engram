# ENGRAM Runtime Configuration
# Copy this file to engram.toml and fill in your values.
# All tokens can also be configured from the dashboard setup wizard.

[workspace]
notion_workspace_id = ""
# Required: share a Notion page with your ENGRAM integration, then paste the page ID here.
# ENGRAM creates all 23 databases under this page.
parent_page_id = ""

[auth]
# Populated from the dashboard setup wizard — never commit real tokens.
notion_mcp_token = ""
anthropic_api_key = ""
github_token = ""
webhook_secret = ""

[server]
host = "127.0.0.1"
port = 3000

[thresholds]
warning_delta_pct = 5.0
critical_delta_pct = 15.0
production_impact_delta_pct = 30.0
baseline_window = 5
pattern_debt_threshold = 5
auto_rfc_severities = ["Critical", "High"]
rfc_stale_days = 14

[schedule]
daily_audit = "0 0 2 * * * *"
weekly_digest = "0 0 9 * * 1 *"
weekly_rfc_staleness = "0 0 10 * * 1 *"
daily_rotation_check = "0 0 3 * * * *"
weekly_knowledge_gap_scan = "0 0 11 * * 1 *"

[user]
# Created automatically during first-start setup — do not edit manually
username = ""
password_hash = ""
display_name = ""
email = ""
role = "admin"
avatar_initials = ""
jwt_secret = ""

[github]
repos = []

[claude]
model = "claude-sonnet-4-20250514"
max_tokens = 4096

# Database IDs — auto-populated when you run Notion setup from dashboard
[databases]
projects = ""
