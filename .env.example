# ENGRAM Environment Variables (OPTIONAL)
#
# You do NOT need a .env file. All configuration is done from the dashboard
# setup wizard on first launch (http://localhost:3000).
#
# This file is only useful for server deployments where you want to inject
# tokens via environment variables instead of the dashboard.

NOTION_MCP_TOKEN=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
WEBHOOK_SECRET=
NOTION_WORKSPACE_ID=

# Optional overrides
ENGRAM_HOST=127.0.0.1
ENGRAM_PORT=3000
CLAUDE_MODEL=claude-sonnet-4-20250514
